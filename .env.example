# ============================================================
# Predictive Analytics Engine - Environment Variables
# ============================================================
# Copie este arquivo para .env e preencha os valores
# Copy this file to .env and fill in the values
# ============================================================

# Ambiente de execucao / Execution environment
# Options: development, staging, production
ENVIRONMENT=development

# Caminhos de dados / Data paths
DATA_PATH=data/
OUTPUT_PATH=output/
MODELS_PATH=models/
LOGS_PATH=logs/

# Configuracao de logging / Logging configuration
LOG_LEVEL=INFO
LOG_FILE=predictive_analytics.log

# Configuracao de modelo / Model configuration
MODEL_TYPE=random_forest
N_ESTIMATORS=100
TEST_SIZE=0.2
RANDOM_STATE=42

# Performance
N_JOBS=-1
BATCH_SIZE=1000
ENABLE_GPU=false
